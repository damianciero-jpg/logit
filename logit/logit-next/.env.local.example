# App mode: "educator" or "trade"
NEXT_PUBLIC_APP_MODE=trade

GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Production-only: exact origin (scheme + host, no trailing slash) the API
# routes should accept requests from, e.g. https://app.example.com.
# Requests with a mismatched Origin header are rejected with 403 when
# NODE_ENV=production. Leave unset in development.
NEXT_PUBLIC_APP_ORIGIN=
